        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Meeting notes\",\n  \"content\": \"Discuss project milestones and deadlines.\",\n  \"category\": \"work\",\n  \"isPinned\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/",
