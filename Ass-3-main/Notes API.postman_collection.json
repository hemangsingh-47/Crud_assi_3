          "raw": "{\n  \"notes\": [\n    {\n      \"title\": \"Note 1\",\n      \"content\": \"First bulk note.\",\n      \"category\": \"study\"\n    },\n    {\n      \"title\": \"Note 2\",\n      \"content\": \"Second bulk note.\",\n      \"category\": \"work\",\n      \"isPinned\": true\n    }\n  ]\n}"
